{
  "name": "ultra-service",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:daemon": "npm run dev -w apps/daemon",
    "dev": "concurrently -n web,daemon -c blue,magenta \"npm:dev:web\" \"npm:dev:daemon\"",
    "build": "npm run build -w apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
